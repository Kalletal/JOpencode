<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="ai.opencode.gui.ImportSessionsController" 
      prefHeight="500.0" prefWidth="600.0" 
      styleClass="main-window" 
      style="-fx-padding: 30; -fx-background-color: #1e1e1e;">
    
    <Label text="Importer des sessions d'Opencode" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
    
    <Label text="Sélectionnez les sessions à importer :" textFill="#cccccc" style="-fx-font-size: 14px;"/>
    
    <ListView fx:id="sessionsListView" VBox.vgrow="ALWAYS" 
              style="-fx-background-color: #2d2d2d; -fx-border-color: #3f3f3f; -fx-border-radius: 5;"/>
    
    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#cancel" style="-fx-background-color: #3d3d3d; -fx-text-fill: #ffffff; -fx-padding: 10 30; -fx-border-radius: 5; -fx-cursor: hand;"/>
        <Button text="Importer" onAction="#importSelected" style="-fx-background-color: #007acc; -fx-text-fill: #ffffff; -fx-padding: 10 30; -fx-border-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>
</VBox>
