<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="700.0" prefWidth="1100.0" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ai.opencode.gui.SettingsController" style="-fx-background-color: #1a1a1a;">

    <!-- ==================== SIDEBAR GAUCHE ==================== -->
    <VBox prefWidth="283.0" minWidth="283.0" maxWidth="283.0" style="-fx-background-color: #1a1a1a; -fx-border-color: #333333; -fx-border-width: 0 1 0 0;">
        <padding>
            <Insets left="10.0" right="10.0" top="15.0" bottom="15.0"/>
        </padding>

        <!-- Logo OPENCODE -->
        <Label text="OPENCODE" style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 0 0 10 5;">
            <font>
                <Font name="System Bold" size="14.0"/>
            </font>
        </Label>

        <!-- Conteneur menu accordéon -->
        <VBox fx:id="menuContainer" VBox.vgrow="ALWAYS" maxWidth="263.0" spacing="4.0" stylesheets="@settings_menu.css" styleClass="sidebar-menu" style="-fx-border-color: #444444; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 4;">

            <!-- Label PARAMÈTRES DE L'INSTANCE -->
            <Label text="PARAMÈTRES DE L'INSTANCE" style="-fx-text-fill: #999999; -fx-font-size: 10; -fx-font-weight: bold; -fx-padding: 2 0 8 2;">
                <font>
                    <Font name="System Bold" size="10.0"/>
                </font>
            </Label>

        <!-- Section: Fournisseurs LLM (expandable) -->
              <VBox prefHeight="35" style="-fx-padding: 6 8 6 8; -fx-background-color: transparent; -fx-background-radius: 6; -fx-cursor: hand;"
                     onMouseClicked="#toggleSectionLLM" onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuHoverExit">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 8;">
                    <ImageView fitWidth="24" fitHeight="24" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@icons/llm.png"/></image>
                    </ImageView>
                    <Label text="Fournisseurs LLM" fx:id="headerTextLLM"
                           style="-fx-text-fill: #cccccc; -fx-font-size: 14; -fx-padding: 0 0 0 4;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text=">" fx:id="chevronLLM" style="-fx-text-fill: #999999; -fx-font-size: 14; -fx-padding: 0 0 0 8;"/>
                </HBox>
            </VBox>
        <HBox fx:id="submenuLLM" id="submenuLLM" minHeight="0" managed="true" spacing="0" style="-fx-padding: 2 0 2 0; -fx-background-color: transparent;">
                <children>
                    <VBox fx:id="vboxLLMChildren" spacing="2" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <children>
                            <HBox HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="35" styleClass="submenu-row" alignment="CENTER_LEFT">
                                <Label fx:id="btnLLMPreference" text="Préférence LLM"
                                       styleClass="subitem" style="-fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 5 10 5 32; -fx-cursor: hand; -fx-max-width: Infinity;"
                                       maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                       onMouseClicked="#showLLMPreference"/>
                            </HBox>
                            <HBox HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="35" styleClass="submenu-row" alignment="CENTER_LEFT">
                                <Label fx:id="btnVoixParole" text="Voix et parole"
                                       styleClass="subitem" style="-fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 5 10 5 32; -fx-cursor: hand; -fx-max-width: Infinity;"
                                       maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                       onMouseClicked="#showVoixParole"/>
                            </HBox>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <!-- Section: Admin (expandable) -->
        <VBox prefHeight="35" style="-fx-padding: 6 8 6 8; -fx-background-color: transparent; -fx-background-radius: 6; -fx-cursor: hand;"
               onMouseClicked="#toggleSectionAdmin" onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuHoverExit">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 8;">
                    <ImageView fitWidth="24" fitHeight="24" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@icons/admin.png"/></image>
                    </ImageView>
                    <Label text="Admin" fx:id="headerTextAdmin"
                           style="-fx-text-fill: #cccccc; -fx-font-size: 14; -fx-padding: 0 0 0 4;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text=">" fx:id="chevronAdmin" style="-fx-text-fill: #999999; -fx-font-size: 14; -fx-padding: 0 0 0 8;"/>
                </HBox>
            </VBox>
            <HBox fx:id="submenuAdmin" id="submenuAdmin" minHeight="0" managed="true" spacing="0" style="-fx-padding: 2 0 2 0; -fx-background-color: transparent;">
                <children>
                    <VBox fx:id="vboxAdminChildren" spacing="2" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <children>
                            <HBox HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="35" styleClass="submenu-row" alignment="CENTER_LEFT">
                                <Label fx:id="btnHistoriqueChats" text="Historique des chats"
                                       styleClass="subitem" style="-fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 5 10 5 32; -fx-cursor: hand; -fx-max-width: Infinity;"
                                       maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                       onMouseClicked="#showHistoriqueChats"/>
                            </HBox>
                            <HBox HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="35" styleClass="submenu-row" alignment="CENTER_LEFT">
                                <Label fx:id="btnDefaultPrompt" text="Default system prompt"
                                       styleClass="subitem" style="-fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 5 10 5 32; -fx-cursor: hand; -fx-max-width: Infinity;"
                                       maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                       onMouseClicked="#showDefaultPrompt"/>
                            </HBox>
                        </children>
                    </VBox>
                </children>
            </HBox>

           <!-- Section: Compétences de l'agent -->
     <VBox prefHeight="35" style="-fx-padding: 6 8 6 8; -fx-background-color: transparent; -fx-background-radius: 6; -fx-cursor: hand;"
              onMouseClicked="#showAgentSkills" onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuHoverExit">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 8;">
                    <ImageView fitWidth="24" fitHeight="24" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@icons/agent_skills.png"/></image>
                    </ImageView>
                    <Label text="Compétences de l'agent" style="-fx-text-fill: #cccccc; -fx-font-size: 14; -fx-padding: 0 0 0 4;"/>
                </HBox>
            </VBox>

          <!-- Section: Apparence (expandable) -->
             <VBox prefHeight="35" style="-fx-padding: 6 8 6 8; -fx-background-color: transparent; -fx-background-radius: 6; -fx-cursor: hand;"
                    onMouseClicked="#toggleSectionAppearance" onMouseEntered="#handleMenuHover" onMouseExited="#handleMenuHoverExit">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 4 0 8;">
                    <ImageView fitWidth="24" fitHeight="24" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@icons/appearance.png"/></image>
                    </ImageView>
                    <Label text="Apparence" fx:id="headerTextAppearance"
                           style="-fx-text-fill: #cccccc; -fx-font-size: 14; -fx-padding: 0 0 0 4;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text=">" fx:id="chevronAppearance" style="-fx-text-fill: #999999; -fx-font-size: 14; -fx-padding: 0 0 0 8;"/>
                </HBox>
            </VBox>
    <HBox fx:id="submenuAppearance" id="submenuAppearance" minHeight="0" managed="true" spacing="0" style="-fx-padding: 2 0 2 0; -fx-background-color: transparent;">
                  <children>
                      <VBox fx:id="vboxAppearanceChildren" spacing="2" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                          <children>
                              <HBox HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="35" styleClass="submenu-row" alignment="CENTER_LEFT">
                                  <Label fx:id="btnInterface" text="Interface"
                                         styleClass="subitem" style="-fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 5 10 5 32; -fx-cursor: hand; -fx-max-width: Infinity;"
                                         maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                         onMouseClicked="#showInterfaceSettings"/>
                              </HBox>
                          </children>
                      </VBox>
                  </children>
              </HBox>

        </VBox>

        <!-- Bottom links -->
        <VBox spacing="8.0" style="-fx-padding: 15 0 0 5;">
            <children>
                <Label text="Contacter le Support" style="-fx-text-fill: #555555; -fx-font-size: 11; -fx-cursor: hand;"
                       onMouseClicked="#openSupport"/>
                <Label text="Confidentialité et données" style="-fx-text-fill: #555555; -fx-font-size: 11; -fx-cursor: hand;"
                       onMouseClicked="#openPrivacy"/>
                <Label text="Licence" style="-fx-text-fill: #555555; -fx-font-size: 11; -fx-cursor: hand;"
                       onMouseClicked="#openLicense"/>
            </children>
        </VBox>
    </VBox>

    <!-- ==================== ZONE DE CONTENU PRINCIPALE ==================== -->
    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #1a1a1a; -fx-padding: 18 18 18 18;">

        <!-- ===== Panneau: Préférence LLM ===== -->
        <VBox fx:id="panelLLMPreference" spacing="20" style="-fx-padding: 10 0 0 0;" visible="true">
            <children>
                <VBox spacing="5">
                    <Label text="Préférence LLM" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                    </Label>
                    <Label text="Voici les identifiants et les paramètres de votre fournisseur de chat et d'intégration préféré. Il est important que ces clés soient actuelles et correctes."
                           style="-fx-text-fill: #999999; -fx-font-size: 13;">
                    </Label>
                </VBox>

                <Separator style="-fx-background-color: #333333; -fx-pref-height: 1;"/>

                <!-- Section Fournisseur LLM -->
                <VBox spacing="15">
                    <Label text="Fournisseur LLM" style="-fx-text-fill: #cccccc; -fx-font-weight: bold; -fx-font-size: 14;">
                        <font>
                            <Font name="System Bold" size="14.0"/>
                        </font>
                    </Label>

                    <!-- Carte de sélection fournisseur -->
                    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #2d2d2d; -fx-border-color: #444444; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 15;"
                          spacing="10" prefWidth="700.0">
                        <children>
                            <Label text="◉" style="-fx-text-fill: #4A90E2; -fx-font-size: 16;"/>
                            <VBox spacing="2">
                                <Label text="OpenAI" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;"/>
                                <Label text="GPT-4o, GPT-4 Turbo, et autres modèles OpenAI" style="-fx-text-fill: #999999; -fx-font-size: 11;"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="▼" style="-fx-text-fill: #666666; -fx-font-size: 12;"/>
                        </children>
                    </HBox>

                    <!-- 3 champs côte à côte -->
                    <HBox spacing="20">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Model context window" style="-fx-text-fill: #999999; -fx-font-size: 12;"/>
                            <ComboBox fx:id="modelContextWindow" prefHeight="40.0" prefWidth="200.0"
                                      style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-border-color: #444444; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                        </VBox>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="API Key" style="-fx-text-fill: #999999; -fx-font-size: 12;"/>
                            <PasswordField fx:id="apiKeyField" prefHeight="40.0" prefWidth="250.0"
                                           style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-border-color: #444444; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                        </VBox>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Modèle" style="-fx-text-fill: #999999; -fx-font-size: 12;"/>
                            <ComboBox fx:id="modelSelector" prefHeight="40.0" prefWidth="200.0"
                                      style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-border-color: #444444; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                        </VBox>
                    </HBox>

                    <!-- Advanced settings pliable -->
                    <VBox spacing="5">
                        <HBox alignment="CENTER_LEFT" style="-fx-cursor: hand;" onMouseClicked="#toggleAdvancedSettings">
                         <children>
                                   <ImageView fitWidth="24" fitHeight="24" pickOnBounds="true" preserveRatio="false">
                                       <image><Image url="@icons/llm.png"/></image>
                                   </ImageView>
                                   <Label text="Advanced settings" style="-fx-text-fill: #cccccc; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand;">
                                      <font>
                                          <Font name="System Bold" size="13.0"/>
                                      </font>
                                  </Label>
                                  <Region HBox.hgrow="ALWAYS"/>
                 <Label text=">" fx:id="chevronAdvanced" style="-fx-text-fill: #999999; -fx-font-size: 13; -fx-padding: 0 0 0 8;"/>
                             </children>
                        </HBox>
                        <VBox fx:id="advancedSettingsPanel" spacing="12" style="-fx-padding: 8 0 0 20;" visible="false">
                            <children>
                                <Label text="Local AI Base URL" style="-fx-text-fill: #999999; -fx-font-size: 12;"/>
                                <TextField fx:id="baseUrlField" prefHeight="40.0" prefWidth="700.0"
                                           style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-border-color: #444444; -fx-border-radius: 6; -fx-background-radius: 6;"
                                           promptText="http://localhost:8080/v1"/>
                            </children>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Boutons action -->
                <HBox alignment="CENTER_RIGHT" spacing="15" VBox.vgrow="ALWAYS">
                    <Button text="Annuler" prefWidth="120.0" prefHeight="35.0"
                            style="-fx-background-color: #3d3d3d; -fx-text-fill: #cccccc; -fx-border-color: #555555; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13; -fx-cursor: hand;"
                            onMouseClicked="#cancelSettings"/>
                    <Button text="Sauvegarder" prefWidth="150.0" prefHeight="35.0"
                            style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand;"
                            onMouseClicked="#saveLLMSettings"/>
                </HBox>
            </children>
        </VBox>

        <!-- ===== Panneau: Historique des chats ===== -->
        <VBox fx:id="panelHistoriqueChats" spacing="20" style="-fx-padding: 10 0 0 0;" visible="false">
            <children>
                <VBox spacing="5">
                    <Label text="Historique des chats" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                    </Label>
                    <Label text="Configurez la durée de conservation et l'affichage de l'historique des conversations."
                           style="-fx-text-fill: #999999; -fx-font-size: 13;"/>
                </VBox>
                <Separator style="-fx-background-color: #333333; -fx-pref-height: 1;"/>
                <VBox spacing="15">
                    <Label text="Durée de conservation" style="-fx-text-fill: #cccccc; -fx-font-weight: bold; -fx-font-size: 14;">
                        <font>
                            <Font name="System Bold" size="14.0"/>
                        </font>
                    </Label>
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="8">
                            <Label text="Conserver l'historique" style="-fx-text-fill: #999999; -fx-font-size: 12;"/>
                            <ComboBox prefHeight="40.0" prefWidth="200.0"
                                      style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-border-color: #444444; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                        </VBox>
                    </HBox>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="15" VBox.vgrow="ALWAYS">
                    <Button text="Annuler" prefWidth="120.0" prefHeight="35.0"
                            style="-fx-background-color: #3d3d3d; -fx-text-fill: #cccccc; -fx-border-color: #555555; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13; -fx-cursor: hand;"
                            onMouseClicked="#cancelSettings"/>
                    <Button text="Sauvegarder" prefWidth="150.0" prefHeight="35.0"
                            style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand;"
                            onMouseClicked="#saveSettings"/>
                </HBox>
            </children>
        </VBox>

        <!-- ===== Panneau: Default system prompt ===== -->
        <VBox fx:id="panelDefaultPrompt" spacing="20" style="-fx-padding: 10 0 0 0;" visible="false">
            <children>
                <VBox spacing="5">
                    <Label text="Default system prompt" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                    </Label>
                    <Label text="Définissez le prompt système par défaut utilisé par l'agent pour toutes les conversations."
                           style="-fx-text-fill: #999999; -fx-font-size: 13;"/>
                </VBox>
                <Separator style="-fx-background-color: #333333; -fx-pref-height: 1;"/>
                <VBox spacing="10">
                    <Label text="Prompt système" style="-fx-text-fill: #cccccc; -fx-font-weight: bold; -fx-font-size: 14;">
                        <font>
                            <Font name="System Bold" size="14.0"/>
                        </font>
                    </Label>
                    <TextArea fx:id="systemPromptArea" prefHeight="300.0" prefWidth="750.0"
                              style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-border-color: #444444; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13;"
                              promptText="Entrez le prompt système par défaut ici..."
                              wrapText="true"/>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="15" VBox.vgrow="ALWAYS">
                    <Button text="Annuler" prefWidth="120.0" prefHeight="35.0"
                            style="-fx-background-color: #3d3d3d; -fx-text-fill: #cccccc; -fx-border-color: #555555; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13; -fx-cursor: hand;"
                            onMouseClicked="#cancelSettings"/>
                    <Button text="Sauvegarder" prefWidth="150.0" prefHeight="35.0"
                            style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand;"
                            onMouseClicked="#saveSettings"/>
                </HBox>
            </children>
        </VBox>

        <!-- ===== Panneau: Interface (Apparence) ===== -->
        <VBox fx:id="panelInterface" spacing="20" style="-fx-padding: 10 0 0 0;" visible="false">
            <children>
                <VBox spacing="5">
                    <Label text="Interface" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                    </Label>
                    <Label text="Personnalisez l'apparence et le comportement de l'interface."
                           style="-fx-text-fill: #999999; -fx-font-size: 13;"/>
                </VBox>
                <Separator style="-fx-background-color: #333333; -fx-pref-height: 1;"/>
                <VBox spacing="15">
                    <Label text="Thème" style="-fx-text-fill: #cccccc; -fx-font-weight: bold; -fx-font-size: 14;">
                        <font>
                            <Font name="System Bold" size="14.0"/>
                        </font>
                    </Label>
                    <VBox spacing="8">
                        <Label text="Thème de l'interface" style="-fx-text-fill: #999999; -fx-font-size: 12;"/>
                        <ComboBox fx:id="themeSelector" prefHeight="40.0" prefWidth="250.0"
                                  style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-border-color: #444444; -fx-border-radius: 6; -fx-background-radius: 6;"
                                  onAction="#applyTheme"/>
                    </VBox>
                    <VBox spacing="8">
                        <Label text="Langue d'affichage" style="-fx-text-fill: #999999; -fx-font-size: 12;"/>
                        <ComboBox fx:id="languageSelector" prefHeight="40.0" prefWidth="250.0"
                                  style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-border-color: #444444; -fx-border-radius: 6; -fx-background-radius: 6;"
                                  onAction="#applyLanguage"/>
                    </VBox>
                </VBox>
            </children>
        </VBox>

        <!-- ===== Panneau: Compétences de l'agent ===== -->
        <VBox fx:id="panelAgentSkills" spacing="20" style="-fx-padding: 10 0 0 0;" visible="false">
            <children>
                <VBox spacing="5">
                    <Label text="Compétences de l'agent" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                    </Label>
                    <Label text="Configurez les compétences et outils disponibles pour l'agent."
                           style="-fx-text-fill: #999999; -fx-font-size: 13;"/>
                </VBox>
                <Separator style="-fx-background-color: #333333; -fx-pref-height: 1;"/>
                <Label text="Ce paramètre sera bientôt disponible." style="-fx-text-fill: #999999; -fx-font-size: 14;"/>
                <HBox alignment="CENTER_RIGHT" spacing="15" VBox.vgrow="ALWAYS">
                    <Button text="Fermer" prefWidth="120.0" prefHeight="35.0"
                            style="-fx-background-color: #3d3d3d; -fx-text-fill: #cccccc; -fx-border-color: #555555; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13; -fx-cursor: hand;"
                            onMouseClicked="#cancelSettings"/>
                </HBox>
            </children>
        </VBox>

        <!-- ===== Panneau: Voix et parole ===== -->
        <VBox fx:id="panelVoixParole" spacing="20" style="-fx-padding: 10 0 0 0;" visible="false">
            <children>
                <VBox spacing="5">
                    <Label text="Voix et parole" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                    </Label>
                    <Label text="Configurez les paramètres de synthèse vocale et de reconnaissance audio."
                           style="-fx-text-fill: #999999; -fx-font-size: 13;"/>
                </VBox>
                <Separator style="-fx-background-color: #333333; -fx-pref-height: 1;"/>
                <Label text="Ce paramètre sera bientôt disponible." style="-fx-text-fill: #999999; -fx-font-size: 14;"/>
                <HBox alignment="CENTER_RIGHT" spacing="15" VBox.vgrow="ALWAYS">
                    <Button text="Fermer" prefWidth="120.0" prefHeight="35.0"
                            style="-fx-background-color: #3d3d3d; -fx-text-fill: #cccccc; -fx-border-color: #555555; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13; -fx-cursor: hand;"
                            onMouseClicked="#cancelSettings"/>
                </HBox>
            </children>
        </VBox>

        <!-- ===== Panneau générique (placeholder) ===== -->
        <VBox fx:id="panelGeneric" spacing="20" style="-fx-padding: 10 0 0 0;" visible="false">
            <children>
                <VBox spacing="5">
                    <Label fx:id="genericPanelTitle" text="Paramètre" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                    </Label>
                    <Label text="Ce paramètre sera bientôt disponible." style="-fx-text-fill: #999999; -fx-font-size: 13;"/>
                </VBox>
                <Separator style="-fx-background-color: #333333; -fx-pref-height: 1;"/>
                <HBox alignment="CENTER_RIGHT" spacing="15" VBox.vgrow="ALWAYS">
                    <Button text="Fermer" prefWidth="120.0" prefHeight="35.0"
